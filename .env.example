# Doubao thinking 模式: disabled / enabled / auto
# auto: 模型按需思考(产品默认,平衡速度和准确率)
# enabled: 总是思考(慢、贵但最准,适合复杂场景调试)
# disabled: 不思考(最快最便宜,简单任务足够)
PHONE_AGENT_THINKING_MODE=auto
